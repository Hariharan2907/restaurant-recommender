# --- Core infrastructure -----------------------------------------------------
# Async SQLAlchemy DSN (psycopg3 driver). Local default matches docker-compose.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/restaurant_recommender
REDIS_URL=redis://localhost:6379/0

# --- Third-party API keys (never shipped to the mobile app) -------------------
ANTHROPIC_API_KEY=
GOOGLE_PLACES_API_KEY=
# Yelp Fusion — used by the background review fetcher (Phase 4).
YELP_API_KEY=

# --- LLM settings --------------------------------------------------------------
# Haiku: query parsing, per-result explanations, dish extraction.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_TIMEOUT_S=3.0
ANTHROPIC_EXPLAIN_TIMEOUT_S=20.0
# Sonnet: /recommendations re-rank with visit history.
ANTHROPIC_RANK_MODEL=claude-sonnet-4-6
ANTHROPIC_RANK_TIMEOUT_S=10.0

# --- Embeddings (Voyage AI — Anthropic's recommended embeddings partner) -------
# voyage-3.5 produces 1024-dim vectors, zero-padded to the schema's vector(1536).
VOYAGE_API_KEY=
VOYAGE_EMBEDDINGS_URL=https://api.voyageai.com/v1/embeddings
VOYAGE_EMBEDDING_MODEL=voyage-3.5
VOYAGE_OUTPUT_DIM=1024
VOYAGE_TIMEOUT_S=10.0

# --- Google Places -------------------------------------------------------------
GOOGLE_PLACES_URL=https://places.googleapis.com/v1/places:searchText
GOOGLE_PLACES_TIMEOUT_S=5.0

# --- Yelp Fusion (background review fetcher) -----------------------------------
YELP_API_URL=https://api.yelp.com/v3
YELP_TIMEOUT_S=5.0

# --- Cache TTLs (seconds) ------------------------------------------------------
SEARCH_CACHE_TTL_S=600       # 10 min
PLACES_CACHE_TTL_S=604800    # 7 days
RECS_CACHE_TTL_S=600         # 10 min
REVIEWS_REFETCH_TTL_S=2592000  # 30 days between review refreshes per restaurant

# --- Supabase Auth -------------------------------------------------------------
# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=
# Anon (publishable) key — safe to expose to clients; backend keeps it for
# completeness/admin tooling.
SUPABASE_ANON_KEY=
# Legacy HS256 JWT secret (Supabase dashboard -> Settings -> API). If set, the
# backend verifies tokens with it. Leave empty to verify against the project
# JWKS endpoint instead (new asymmetric signing keys).
SUPABASE_JWT_SECRET=
# Optional override; defaults to {SUPABASE_URL}/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUD=authenticated

# --- Runtime -------------------------------------------------------------------
# "development" | "production". Production switches to JSON logs and hides
# error details from API responses.
ENVIRONMENT=development
LOG_LEVEL=INFO
# Sentry error tracking (optional — disabled when empty).
SENTRY_DSN=

# Comma/JSON list of allowed CORS origins (never "*").
# CORS_ORIGINS=["http://localhost:8081","http://localhost:19006"]

# --- Rate limiting (fixed 60s windows, Redis-backed) ---------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_SEARCH_USER_PER_MIN=10
RATE_LIMIT_SEARCH_IP_PER_MIN=30
RATE_LIMIT_RECS_USER_PER_MIN=6
RATE_LIMIT_RECS_IP_PER_MIN=20
RATE_LIMIT_DEFAULT_USER_PER_MIN=60
RATE_LIMIT_DEFAULT_IP_PER_MIN=120

# --- Request hardening ----------------------------------------------------------
MAX_REQUEST_BYTES=65536
