{
  "expo": {
    "name": "Restaurant Recommender",
    "slug": "restaurant-recommender",
    "scheme": "restaurantrecommender",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.restaurantrecommender.app"
    },
    "android": {
      "package": "com.restaurantrecommender.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
